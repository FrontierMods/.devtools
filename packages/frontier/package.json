{
	"name": "@frmds/frontier",
	"version": "0.6.0",
	"description": "Core tooling for the Frontier Mods `.devtools`",
	"keywords": [
		"cataclysm",
		"cataclysm-dda",
		"cdda",
		"modding",
		"toolkit"
	],
	"homepage": "https://github.com/FrontierMods/.devtools",
	"bugs": {
		"url": "https://github.com/FrontierMods/.devtools/issues",
		"email": "frontiermods@protonmail.com"
	},
	"license": "MIT",
	"author": {
		"name": "Steve Brand",
		"email": "thatfanficguy@protonmail.com",
		"url": "https://github.com/Hyperseeker"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/FrontierMods/.devtools.git",
		"directory": "packages/frontier"
	},
	"bin": {
		"frontier": "dist/index.js"
	},
	"files": [
		"LICENSE",
		"package.json",
		"README.md",
		"dist/"
	],
	"type": "module",
	"main": "dist/index.js",
	"types": "./dist/exports.d.ts",
	"exports": {
		".": {
			"types": "./dist/exports.d.ts",
			"default": "./dist/exports.js"
		}
	},
	"scripts": {
		"build": "tsgo -b",
		"watch": "tsgo --watch",
		"lint": "oxlint --type-aware",
		"format": "oxfmt",
		"format:check": "oxfmt --check",
		"typecheck": "tsgo --noEmit",
		"test": "bun test",
		"prepublishOnly": "bun run lint && bun run format:check && bun run test && bun run build"
	},
	"dependencies": {
		"@logtape/file": "^2.2.0",
		"@logtape/logtape": "^2.2.0",
		"@logtape/pretty": "^2.2.0",
		"@stricli/core": "^1.2.8",
		"env-paths": "^4.0.0",
		"fs-extra": "^11.3.5",
		"global-directory": "^5.0.0",
		"immutable-json-patch": "^6.0.2",
		"lmdb": "^3.5.6",
		"picomatch": "^4.0.4",
		"sysfind": "^1.0.0",
		"tinyglobby": "^0.2.17",
		"typebox": "^1.3.0",
		"xxhash-wasm": "^1.1.0"
	},
	"devDependencies": {
		"@types/fs-extra": "^11.0.4",
		"@types/picomatch": "^4.0.3",
		"@typescript/native-preview": "^7.0.0-dev.20260622.1",
		"oxfmt": "^0.55.0",
		"oxlint": "^1.70.0",
		"oxlint-tsgolint": "^0.23.0"
	},
	"engines": {
		"bun": ">=1.3.0"
	}
}
