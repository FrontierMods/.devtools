{
	"name": "@frmds/init",
	"version": "1.0.0",
	"description": "Initialize a new Frontier mod structure",
	"keywords": [
		"frontier-plugin"
	],
	"homepage": "https://github.com/FrontierMods/.devtools",
	"bugs": {
		"url": "https://github.com/FrontierMods/.devtools/issues",
		"email": "frontiermods@protonmail.com"
	},
	"license": "MIT",
	"author": {
		"name": "Hyperseeker",
		"email": "thatfanficguy@protonmail.com",
		"url": "https://github.com/Hyperseeker"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/FrontierMods/.devtools.git",
		"directory": "packages/init"
	},
	"funding": [
		"https://ko-fi.com/frontiermods",
		"https://www.buymeacoffee.com/frontiermods"
	],
	"files": [
		"LICENSE",
		"package.json",
		"README.md",
		"dist/",
		"templates/"
	],
	"type": "module",
	"exports": {
		"./plugin": {
			"types": "./dist/plugin.d.ts",
			"import": "./dist/plugin.js"
		}
	},
	"scripts": {
		"build": "tsgo -b",
		"watch": "tsgo --watch",
		"lint": "oxlint --type-aware",
		"format": "oxfmt",
		"format:check": "oxfmt --check",
		"typecheck": "tsgo --noEmit",
		"prepublishOnly": "bun run lint && bun run format:check && bun run build",
		"postinstall": "frontier plugins add @frmds/init || exit 0",
		"preuninstall": "frontier plugins remove @frmds/init || exit 0"
	},
	"dependencies": {
		"@frmds/frontier": "^0.6.0",
		"fs-extra": "^11.3.5"
	},
	"devDependencies": {
		"@types/fs-extra": "^11.0.4",
		"@typescript/native-preview": "^7.0.0-dev.20260607.1",
		"oxfmt": "^0.53.0",
		"oxlint": "^1.68.0",
		"oxlint-tsgolint": "^0.23.0"
	},
	"peerDependencies": {
		"@stricli/core": "^1.2.7"
	},
	"engines": {
		"node": ">=20.11"
	}
}
